CREATE OR REPLACE PROCEDURE "sp_place_order"(p_customer_id INT, p_total_amount NUMERIC, p_shipping_address TEXT, p_payment_method TEXT, p_discount_amount NUMERIC, p_tax_amount NUMERIC, p_notes TEXT, p_is_express BOOLEAN
) LANGUAGE plpgsql AS $$
DECLARE
    v_exists INT := 0;
BEGIN
    SELECT COUNT(*) INTO v_exists FROM customers WHERE customer_id = p_customer_id AND is_active = TRUE;
    
    IF v_exists = 0 THEN
        RAISE EXCEPTION 'Customer does not exist or is inactive';
    ELSE
        INSERT INTO orders (customer_id, total_amount, shipping_address, payment_method, discount_amount, tax_amount, notes, is_express)
        VALUES (p_customer_id, p_total_amount, p_shipping_address, p_payment_method, p_discount_amount, p_tax_amount, p_notes, p_is_express);
        
        SELECT lastval() AS new_order_id;
    END IF;
END;
$$;
