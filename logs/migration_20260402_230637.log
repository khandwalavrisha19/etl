CREATE OR REPLACE FUNCTION "fn_customer_avg_order_value"(p_customer_id INT) RETURNS NUMERIC LANGUAGE plpgsql AS $$
DECLARE
    v_avg NUMERIC;
BEGIN
    SELECT AVG(total_amount) INTO v_avg 
    FROM orders 
    WHERE customer_id = p_customer_id AND status IN ('shipped','delivered');
    RETURN COALESCE(v_avg, 0.00);
END;
$$;
