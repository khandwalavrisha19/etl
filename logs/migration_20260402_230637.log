CREATE OR REPLACE FUNCTION "fn_customer_lifetime_value"(p_customer_id INT) RETURNS NUMERIC LANGUAGE plpgsql AS $$
DECLARE
    v_total NUMERIC;
BEGIN
    SELECT total_spent + (loyalty_points * 0.5) INTO v_total 
    FROM customers WHERE customer_id = p_customer_id;
    RETURN COALESCE(v_total, 0.00);
END;
$$;
