2026-04-02 23:06:49 - migration - DEBUG - Creating routine fn_monthly_revenue:
CREATE OR REPLACE FUNCTION "fn_monthly_revenue"(p_year INT, p_month INT) RETURNS NUMERIC LANGUAGE plpgsql AS $$
DECLARE
    v_rev NUMERIC;
BEGIN
    SELECT SUM(total_amount) INTO v_rev
    FROM orders
    WHERE YEAR(order_date) = p_year 
      AND MONTH(order_date) = p_month
      AND status IN ('shipped','delivered');
    RETURN COALESCE(v_rev, 0.00);
END;
$$;
