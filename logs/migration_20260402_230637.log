CREATE OR REPLACE PROCEDURE "sp_add_customer"(p_first_name VARCHAR(50), p_last_name VARCHAR(50), p_email VARCHAR(255), p_phone_number VARCHAR(20), p_address TEXT, p_city VARCHAR(100), p_state VARCHAR(100), p_postal_code VARCHAR(20), p_date_of_birth DATE, p_membership_tier TEXT
) LANGUAGE plpgsql AS $$
BEGIN
    INSERT INTO customers (first_name, last_name, email, phone_number, address, city, state, postal_code, date_of_birth, membership_tier)
    VALUES (p_first_name, p_last_name, p_email, p_phone_number, p_address, p_city, p_state, p_postal_code, p_date_of_birth, p_membership_tier);
    
    SELECT lastval() AS new_customer_id;
END;
$$;
