CREATE OR REPLACE FUNCTION "fn_customer_active_orders_count"(p_customer_id INT, p_days INT) RETURNS int LANGUAGE plpgsql AS $$
DECLARE
    v_count INT;
BEGIN
    SELECT COUNT(*) INTO v_count
    FROM orders o
    WHERE o.customer_id = p_customer_id 
      AND o.status NOT IN ('delivered','cancelled')
      AND o.order_date >= (CURRENT_TIMESTAMP - (p_days * INTERVAL \'1 day\'));
    RETURN COALESCE(v_count, 0);
END;
$$;
