CREATE OR REPLACE PROCEDURE "sp_update_customer_metrics"(p_customer_id INT, p_order_amount DECIMAL(12,2)) LANGUAGE plpgsql AS $$
BEGIN
    UPDATE customers 
    SET total_spent = total_spent + p_order_amount,
        loyalty_points = loyalty_points + FLOOR(p_order_amount / 10),
        membership_tier = CASE 
            WHEN total_spent + p_order_amount >= 50000 THEN 'vip'
            WHEN total_spent + p_order_amount >= 25000 THEN 'premium'
            ELSE membership_tier 
        END;
$$;
    WHERE customer_id = p_customer_id AND is_active = TRUE;
    
    SELECT ROW_COUNT() AS updated, loyalty_points, membership_tier 
    FROM customers WHERE customer_id = p_customer_id;
END;
$$;
