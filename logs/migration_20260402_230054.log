CREATE OR REPLACE PROCEDURE "sp_get_order_details"(p_order_id INT) LANGUAGE plpgsql AS $$
BEGIN
    SELECT 
        o.order_id, o.order_date, o.status, o.total_amount, 
        (o.total_amount - o.discount_amount + o.tax_amount) AS grand_total,
        CONCAT(c.first_name, ' ', c.last_name) AS customer_name,
        c.email, c.membership_tier
    FROM orders o
    INNER JOIN customers c ON o.customer_id = c.customer_id
    WHERE o.order_id = p_order_id;

    SELECT * FROM order_items WHERE order_id = p_order_id ORDER BY item_id;
END;
$$;
