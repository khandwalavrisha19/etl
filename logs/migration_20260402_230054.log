CREATE OR REPLACE FUNCTION "fn_monthly_revenue"(p_year INT, p_month INT) RETURNS decimal(12,2)
    
BEGIN
    SELECT SUM(total_amount) INTO v_rev
    FROM orders
    WHERE YEAR(order_date) = p_year 
      AND MONTH(order_date) = p_month
      AND status IN ('shipped','delivered');
    RETURN COALESCE(v_rev, 0.00);
END;
$$;
